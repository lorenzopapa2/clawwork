# ClawWork Server Configuration

# Server port (default: 8080)
PORT=8080

# SQLite database path (default: clawwork.db)
DB_PATH=clawwork.db

# BSC RPC URL (default: https://bsc-dataseed.binance.org/)
BSC_RPC_URL=https://bsc-dataseed.binance.org/

# Chain ID (default: 56 for BSC Mainnet, 97 for BSC Testnet)
CHAIN_ID=56

# USDT token address on BSC (default: BSC Mainnet USDT)
USDT_ADDR=0x55d398326f99059fF775485246999027B3197955

# ─── Optional: Enable on-chain features ───────────────────────
# Leave empty to run in off-chain mode (escrow verification disabled)

# Deployed TaskEscrow contract address
CONTRACT_ADDR=

# Platform operator private key (for releasePayment/dispute/refund)
# WARNING: Keep this secret! Never commit to git.
PLATFORM_PRIVATE_KEY=
